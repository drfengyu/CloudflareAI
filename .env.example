# ──────────────────────────────────────────────────────────────
# Cloudflare AI Console — environment variables
# Copy to .env.local for development; set the same in Vercel project settings.
# ──────────────────────────────────────────────────────────────

# Cloudflare account that hosts Workers AI, D1 and KV (platform-level).
CF_ACCOUNT_ID=
# API token scoped to: Workers AI (Read/Run), D1 (Edit), Workers KV (Edit),
# Account Analytics (Read).
CF_API_TOKEN=
# D1 database id (create via `wrangler d1 create cf-ai-console`).
CF_D1_DATABASE_ID=
# KV namespace id (create via `wrangler kv namespace create cf-ai-console`).
CF_KV_NAMESPACE_ID=

# Auth.js — generate with `openssl rand -base64 32`.
AUTH_SECRET=
# Optional GitHub OAuth (leave blank to use email/password only).
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# API Key encryption secret (AES-256-GCM, generate with `openssl rand -base64 32`).
API_KEY_ENCRYPTION_SECRET=

# Public base URL of the deployment (used in API docs / examples).
NEXT_PUBLIC_APP_URL=http://localhost:3000
